  "instructions": {
    "order": [
      "1. Tạo Users trước (cần userId cho Farm)",
      "2. Tạo Farms (cần ownerId từ Users)",
      "3. Tạo Products (dữ liệu độc lập)",
      "4. Tạo CropSeasons (cần farmId và productId)",
      "5. Tạo Workers (dữ liệu độc lập)",
      "6. Tạo TaskTypes (cần farmId)",
      "7. Tạo PlantPositions (cần farmId, seasonId, productId)",
      "8. Tạo DailyWorkLogs (cần seasonId, taskTypeId)",
      "9. Tạo WorkAssignments (cần logId, workerId)",
      "10. Tạo WorkerAdvances (cần workerId, seasonId)",
      "11. Tạo MaterialUsages (cần seasonId)",
      "12. Tạo HarvestSessions (cần seasonId)",
      "13. Tạo HarvestBagDetails (cần sessionId)",
      "14. Tạo FarmSales (cần seasonId)",
      "15. Tạo WeatherLogs (cần farmId)",
      "16. Tạo UserLoginLogs (cần userId)"
    ],
