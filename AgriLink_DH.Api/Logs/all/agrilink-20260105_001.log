SELECT d.id, d.deleted_at, d.is_deleted, d.note, d.season_id, d.task_type_id, d.total_cost, d.work_date, c.id, c.deleted_at, c.end_date, c.farm_id, c.is_deleted, c.name, c.note, c.product_id, c.start_date, c.status, p.id, p.code, p.image_url, p.name, p.unit, t.id, t.default_price, t.default_unit, t.farm_id, t.name, s.id, s.log_id, s.note, s.payment_method, s.quantity, s.total_amount, s.unit_price, s.worker_id, s.id0, s.default_daily_wage, s."FarmId", s.full_name, s.image_url, s.is_active, s.phone, s.worker_type
FROM daily_work_logs AS d
INNER JOIN crop_seasons AS c ON d.season_id = c.id
INNER JOIN products AS p ON c.product_id = p.id
LEFT JOIN task_types AS t ON d.task_type_id = t.id
LEFT JOIN (
    SELECT w.id, w.log_id, w.note, w.payment_method, w.quantity, w.total_amount, w.unit_price, w.worker_id, w0.id AS id0, w0.default_daily_wage, w0."FarmId", w0.full_name, w0.image_url, w0.is_active, w0.phone, w0.worker_type
    FROM work_assignments AS w
    INNER JOIN workers AS w0 ON w.worker_id = w0.id
) AS s ON d.id = s.log_id
WHERE d.task_type_id = @__taskTypeId_0
ORDER BY d.work_date DESC, d.id, c.id, p.id, t.id, s.id
